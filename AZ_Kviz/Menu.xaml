<Window x:Class="AZ_Kviz.Menu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AZ_Kviz"
        mc:Ignorable="d"
        Title="AZ-kvíz" Height="500" Width="800" FontFamily="Arial">
    <Grid>
        <Label Content="AZ-kvíz" FontWeight="Bold" FontSize="40" Width="220" Margin="290,50,290,305" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Arial" HorizontalContentAlignment="Center"/>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Vertical" Margin="20" Width="300">
            <Button x:Name="Hra" Content="Nová hra" Height="45" Margin="5" FontSize="20" Background="Orange" Cursor="Hand" Click="Hra_Click" />
            <Button x:Name="Nastaveni" Content="Nastavení" Height="45" Margin="5" FontSize="20" Background="Orange" Cursor="Hand" Click="Nastaveni_Click" />
            <Button x:Name="Konec" Content="Konec hry" Height="45" Margin="5" FontSize="20" Background="Orange" Cursor="Hand" Click="Konec_Click" />
        </StackPanel>

    </Grid>
</Window>
