<Window x:Class="AZ_Kviz.Nastaveni"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AZ_Kviz"
        mc:Ignorable="d"
        Title="Nastavení" Height="500" Width="830">
    <Grid>
        <Label Content="Nastavení" FontWeight="Bold" FontSize="40" Width="220" Margin="0,87,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" FontFamily="Arial" HorizontalContentAlignment="Center"/>
        <Button x:Name="databaze" Content="Databáze otázek" Height="45" Width="250" Margin="275,195,275,194" FontSize="20" Background="Orange" Cursor="Hand" Click="Databaze_Click" />
        <Button x:Name="zpet" Content="Zpět" Height="45" Width="150" Margin="325,345,325,44" FontSize="20" Background="Orange" Cursor="Hand" Click="Konec_Click" />
    </Grid>
</Window>
