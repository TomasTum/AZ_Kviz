<Window x:Class="AZ_Kviz.Nastaveni"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AZ_Kviz"
        mc:Ignorable="d"
        Title="Nastavení"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        FontFamily="Arial">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label Content="Nastavení" FontWeight="Bold" FontSize="40" Width="220" HorizontalContentAlignment="Center"/>
            <Button x:Name="databaze" Content="Databáze otázek" Height="45" Width="250" FontSize="20" Margin="0,150,0,0" Background="Orange" Cursor="Hand" Click="Databaze_Click" />
            <Button x:Name="zpet" Content="Zpět" Height="45" Width="150"  FontSize="20" Margin="0,250,0,30" Background="Orange" Cursor="Hand" Click="Konec_Click" />
        </StackPanel>
        
    </Grid>
</Window>
