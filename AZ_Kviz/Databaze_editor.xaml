<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AZ_Kviz"
        xmlns:Sqlite="clr-namespace:Microsoft.Data.Sqlite;assembly=Microsoft.Data.Sqlite" x:Class="AZ_Kviz.Databaze_editor"
        mc:Ignorable="d"
        Title="Databaze_editor" Height="450" Width="800">
    <Grid>
        <Label Content="Databáze" FontWeight="Bold" FontSize="40" Width="220" Margin="290,50,290,305" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Arial" HorizontalContentAlignment="Center"/>
        <DataGrid HorizontalAlignment="Center" Height="163" Margin="0,158,0,0" VerticalAlignment="Top" Width="696">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" FontSize="14"/>
                <DataGridTextColumn Header="Otázka" FontSize="14"/>
                <DataGridTextColumn Header="Správná odpověď" FontSize="14"/>
                <DataGridTextColumn Header="Kategorie" FontSize="14"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Window>
