<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AZ_Kviz"
        xmlns:Sqlite="clr-namespace:Microsoft.Data.Sqlite;assembly=Microsoft.Data.Sqlite" x:Class="AZ_Kviz.Databaze_editor"
        mc:Ignorable="d"
        SizeToContent="WidthAndHeight"
        MinHeight="700" MinWidth="920"
        Title="Editor databáze otázek" >
    <Grid Loaded="Grid_Loaded">
        <Label Content="Databáze" FontWeight="Bold" FontSize="40" Width="220" Margin="0,52,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" FontFamily="Arial" HorizontalContentAlignment="Center"/>
        <DataGrid x:Name="Datagrid" HorizontalAlignment="Center" Height="270" Margin="0,136,0,0" VerticalAlignment="Top" Width="624" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ID" Header="ID" FontSize="14" Binding="{Binding Id}"/>
                <DataGridTextColumn x:Name="Otazka" Header="Otázka" FontSize="14" Binding="{Binding Otazka}"/>
                <DataGridTextColumn x:Name="SpravnaOdpoved" Header="Správná odpověď" FontSize="14" Binding="{Binding SpravnaOdpoved}"/>
                <DataGridTextColumn x:Name="Kategorie" Header="Kategorie" FontSize="14" Binding="{Binding Kategorie}"/>
            </DataGrid.Columns>
        </DataGrid>
        <Button Content="Přidat otázku" Margin="188,454,485,185" Height="45" Width="250" FontSize="20" Cursor="Hand" Click="Pridat_Click">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFFFCF78" Offset="0.109"/>
                    <GradientStop Color="Orange" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button Content="Odebrat otázku" Margin="482,454,188,185" Height="45" Width="250" FontSize="20" Cursor="Hand" Click="Odebrat_Click">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFFFCF78" Offset="0.109"/>
                    <GradientStop Color="Orange" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>

        <Button Content="Aktualizovat" Margin="336,524,337,115" Height="45" Width="250" FontSize="20" Cursor="Hand" Click="Aktualizovat_Click">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFFFCF78" Offset="0.109"/>
                    <GradientStop Color="Orange" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
        <Button x:Name="zpet" Content="Zpět" Height="45" Width="150" Margin="375,594,375,45" Click="Konec_Click" FontSize="20" Cursor="Hand">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFFFCF78" Offset="0.109"/>
                    <GradientStop Color="Orange" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>
    </Grid>
</Window>
