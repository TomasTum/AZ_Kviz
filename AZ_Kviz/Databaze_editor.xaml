<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AZ_Kviz"
        xmlns:Sqlite="clr-namespace:Microsoft.Data.Sqlite;assembly=Microsoft.Data.Sqlite" 
        x:Class="AZ_Kviz.Databaze_editor"
        mc:Ignorable="d"
        Title="Databáze otázek"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        FontFamily="Arial">
    <Grid Loaded="Grid_Loaded">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label Content="Databáze" FontWeight="Bold" FontSize="40" Margin="0,0,0,0" HorizontalContentAlignment="Center"/>
            <DataGrid x:Name="Datagrid" Height="450" Margin="20,20,20,20" AutoGenerateColumns="False" FontSize="18" CanUserAddRows="False" Cursor="Hand">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ID" Header="ID" Binding="{Binding Id}"/>
                    <DataGridTextColumn x:Name="Otazka" Header="Otázka" Binding="{Binding Otazka}"/>
                    <DataGridTextColumn x:Name="SpravnaOdpoved" Header="Správná odpověď" Binding="{Binding SpravnaOdpoved}"/>
                    <DataGridTextColumn x:Name="Zkratka" Header="Zkratka" Binding="{Binding Zkratka}"/>
                    <DataGridTextColumn x:Name="Kategorie" Header="Kategorie" Binding="{Binding Kategorie}"/>
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="20,0,20,15" Cursor="">
                <Button Content="Přidat otázku" Margin="0,0,15,0" Height="45" Width="250" FontSize="20" Background="Orange" Cursor="Hand" Click="Pridat_Click" />
                <Button Content="Upravit otázku" Margin="0,0,15,0" Height="45" Width="250" FontSize="20" Background="Orange" Cursor="Hand" Click="Upravit_Click" />
                <Button Content="Odebrat otázku" Margin="0,0,0,0" Height="45" Width="250" FontSize="20" Background="Orange" Cursor="Hand" Click="Odebrat_Click" />
            </StackPanel>
            <Button Content="Aktualizovat data" Margin="0,0,0,50" Height="45" Width="250" FontSize="20" Background="Orange" Cursor="Hand" Click="Aktualizovat_Click" />
            <Button x:Name="zpet" Content="Zpět" Margin="0,0,0,20" Height="45" Width="150"  FontSize="20" Background="Orange" Cursor="Hand" Click="Konec_Click" />
        </StackPanel>
    </Grid>
</Window>
