<UserControl x:Class="AZ_Kviz.Hra"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        KeyDown="Window_KeyDown"
        FontFamily="Arial">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="40,20,40,10">

            <Grid x:Name="Player1Panel" HorizontalAlignment="Left" Height="80">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="Auto" MinWidth="160" />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>

                <Polygon Grid.Column="0" Points="30,0 0,40 30,80" Fill="Orange" />
                <Rectangle Grid.Column="1" Fill="Orange" Margin="-1,0,-1,0" />
                <Polygon Grid.Column="2" Points="0,0 30,40 0,80" Fill="Orange" />

                <Polyline Grid.Column="0" Points="30,0 0,40 30,80" Stroke="#E67E22" StrokeThickness="2" />
                <Border Grid.Column="1" BorderBrush="#E67E22" BorderThickness="0,2,0,2" />
                <Polyline Grid.Column="2" Points="0,0 30,40 0,80" Stroke="#E67E22" StrokeThickness="2" />

                <TextBlock Grid.Column="1" x:Name="TxtPlayer1Name" Text="Hráč 1" FontSize="24" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0"/>
            </Grid>

            <Grid x:Name="Player2Panel" HorizontalAlignment="Right" Height="80">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="Auto" MinWidth="160" />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>

                <Polygon Grid.Column="0" Points="30,0 0,40 30,80" Fill="DeepSkyBlue" />
                <Rectangle Grid.Column="1" Fill="DeepSkyBlue" Margin="-1,0,-1,0" />
                <Polygon Grid.Column="2" Points="0,0 30,40 0,80" Fill="DeepSkyBlue" />

                <Polyline Grid.Column="0" Points="30,0 0,40 30,80" Stroke="#1F618D" StrokeThickness="2" />
                <Border Grid.Column="1" BorderBrush="#1F618D" BorderThickness="0,2,0,2" Margin="-1,0,-1,0" />
                <Polyline Grid.Column="2" Points="0,0 30,40 0,80" Stroke="#1F618D" StrokeThickness="2" />

                <TextBlock Grid.Column="1" x:Name="TxtPlayer2Name" Text="Hráč 2" FontSize="24" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0"/>
            </Grid>

        </Grid>

        <Viewbox Grid.Row="1" Margin="20" Stretch="Uniform">
            <Canvas x:Name="GameBoard"
                Grid.Row="1"
                Height="450" 
                Width="600"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                Background="Transparent"/>
        </Viewbox>

        <StackPanel x:Name="QuestionArea"
                    Grid.Row="2"
                    Visibility="Collapsed"
                    Margin="0,0,0,40" 
                    HorizontalAlignment="Center">

            <TextBlock x:Name="TxtQuestion" 
                       Text="..." 
                       FontSize="24" 
                       Margin="0,0,0,20" 
                       TextAlignment="Center" 
                       TextWrapping="Wrap" 
                       MaxWidth="800"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Grid Width="80" Height="80" Margin="0,0,20,0">
                    <Polygon Points="40,0 80,20 80,60 40,80 0,60 0,20" Fill="White" Stroke="Black" StrokeThickness="2" />

                    <Viewbox MaxWidth="55" MaxHeight="45" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtHint" 
                           Text="V" 
                           FontSize="30" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
                    </Viewbox>
                </Grid>

                <StackPanel VerticalAlignment="Center">
                    <TextBox x:Name="TxtAnswer" Width="300" Padding="8" FontSize="18"/>

                    <Button x:Name="BtnSubmit"
                            Content="Odpovědět" 
                            Click="BtnSubmit_Click" 
                            Margin="0,10,0,0" 
                            Padding="10" 
                            Width="300"
                            FontSize="20"
                            FontWeight="Bold"
                            Background="Orange"
                            Foreground="Black"
                            Cursor="Hand"
                            IsDefault="True"/>

                    <TextBlock x:Name="TxtCorrectAnswer" 
                               Text="Správná odpověď: ..." 
                               Foreground="Red" 
                               FontWeight="Bold" 
                               FontSize="20" 
                               Margin="0,10,0,0" 
                               HorizontalAlignment="Center" 
                               Visibility="Collapsed"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <StackPanel x:Name="SubQuestionArea"
            Grid.Row="2"
            Visibility="Collapsed" 
            Margin="0,0,0,40" 
            HorizontalAlignment="Center">

            <TextBlock x:Name="TxtSubQuestion" 
               Text="..." 
               FontSize="24" 
               Margin="0,0,0,20" 
               TextAlignment="Center" 
               TextWrapping="Wrap" 
               MaxWidth="800"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnYes" Content="ANO" Width="150" Height="70" Margin="10" Click="BtnYes_Click" Background="Orange" FontSize="22" FontWeight="Bold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Polygon Points="20,0 130,0 150,35 130,70 20,70 0,35" 
                                    Fill="{TemplateBinding Background}" 
                                    Stroke="#E67E22" StrokeThickness="1"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnNo" Content="NE" Width="150" Height="70" Margin="10" Click="BtnNo_Click" Background="DeepSkyBlue" FontSize="22" FontWeight="Bold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Polygon Points="20,0 130,0 150,35 130,70 20,70 0,35" 
                                    Fill="{TemplateBinding Background}" 
                                    Stroke="#1F618D" StrokeThickness="1"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
            <TextBlock x:Name="TxtSubCorrectAnswer" 
               Text="Správná odpověď: ..." 
               Foreground="Red" 
               FontWeight="Bold" 
               FontSize="20" 
               Margin="0,10,0,0" 
               HorizontalAlignment="Center" 
               Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</UserControl>